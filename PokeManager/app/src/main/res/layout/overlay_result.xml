<?xml version="1.0" encoding="utf-8"?>
<!-- PokeGenie iVision 스타일 — 작은 카드 (좌상단), 핵심 5줄 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/result_card_bg"
    android:padding="10dp"
    android:elevation="8dp">

    <!-- 1줄: 이름 (작게) -->
    <TextView
        android:id="@+id/tvName"
        android:text="화살꼬빈"
        android:textColor="#222"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp" />

    <!-- 2줄: IV % + Atk-Def-Sta (강조 큰 글씨) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:text="IV"
            android:textColor="#444"
            android:textSize="11sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvIV"
            android:text="38%"
            android:textColor="#000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvIvBreakdown"
            android:text="(4-9-4)"
            android:textColor="#555"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- 3-5줄: 슈/하/마 리그 (한 줄씩, 컴팩트) -->
    <TextView
        android:id="@+id/tvLeagueGL"
        android:text="🏆 67.9% (0)"
        android:textColor="#388E3C"
        android:textSize="11sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp" />

    <TextView
        android:id="@+id/tvLeagueUL"
        android:text="🥇 41.1% (2)"
        android:textColor="#1976D2"
        android:textSize="11sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp" />

    <TextView
        android:id="@+id/tvLeagueML"
        android:text="🥈 27.1% (2)"
        android:textColor="#616161"
        android:textSize="11sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <!-- 6줄: CP + Lv -->
    <TextView
        android:id="@+id/tvCpLv"
        android:text="CP 382, Lv 20.0"
        android:textColor="#222"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp" />

    <!-- 7줄 (옵션): 결정 / 후보 개수 알림 -->
    <TextView
        android:id="@+id/tvHint"
        android:text=""
        android:textColor="#D32F2F"
        android:textSize="10sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>
