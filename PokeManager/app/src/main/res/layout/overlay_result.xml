<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE1A237E"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvName"
        android:text="포켓몬 이름"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvCP"
        android:text="CP 0  HP 0  먼지 0"
        android:textColor="#B3E5FC"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvIV"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvLeague"
        android:text=""
        android:textColor="#FFD54F"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <!-- 별가루 입력 — IV 후보 좁히기 (detail 화면엔 별가루 없음) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:text="별가루:"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <EditText
            android:id="@+id/etDust"
            android:hint="2500"
            android:textColorHint="#80FFFFFF"
            android:textColor="#FFFFFF"
            android:inputType="number"
            android:textSize="13sp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnRecalc"
            android:text="재계산"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- 후보 list — perfection 별 모든 가능 IV 조합 (스크롤) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="180dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvCandidates"
            android:text=""
            android:textColor="#E0E0E0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnSave"
            android:text="저장"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <Button
            android:id="@+id/btnClose"
            android:text="닫기"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
