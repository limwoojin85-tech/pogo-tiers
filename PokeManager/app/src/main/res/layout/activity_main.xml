<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:text="PokeManager"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:text="중지됨"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp" />

    <!-- 캡처 모드 선택 — 시작 전에 미리 결정 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="캡처 모드"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgCaptureMode"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rbModeFull"
            android:text="전체 화면 (분할화면 좌/우 동시 분석)"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbModeSingle"
            android:text="앱 하나만 (포고만 캡처)" />
    </RadioGroup>

    <Button
        android:id="@+id/btnToggle"
        android:text="오버레이 시작"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnMyPokemon"
        android:text="내 포켓몬 리스트"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="240dp"
        android:layout_height="56dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="12sp"
        android:gravity="center"
        android:text="• 전체 화면 = 분할화면 좌/우 양쪽 다 분석 + 자동 [A]/[B] 프로필 분리\n• 앱 하나 = 포고만 캡처 (분할화면 OFF, 단일 계정)" />

</LinearLayout>
